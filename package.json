{
  "name": "org-planner",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm -w packages/client run dev",
    "dev:server": "npm -w packages/server run dev",
    "build": "npm -w packages/server run build && npm -w packages/client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
